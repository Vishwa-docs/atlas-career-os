# ---- Atlas backend environment (copy to .env; never commit real secrets) ----

# App
ENVIRONMENT=local
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-string-at-least-32-characters

# Database (Postgres + pgvector). Async driver is forced automatically.
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas

# Redis (ARQ jobs, caching, pub/sub)
REDIS_URL=redis://localhost:6379/0

# ---- Azure OpenAI ----
# Leave USE_MOCK_LLM=true to run fully offline with the deterministic mock.
# Set USE_MOCK_LLM=false and fill the four values below to use the real model.
USE_MOCK_LLM=true
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_API_VERSION=2024-10-21
EMBEDDING_DIMENSIONS=1536

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
